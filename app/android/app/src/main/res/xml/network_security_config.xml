<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows HTTP listener links from LAN QR codes (e.g. http://192.168.x.x:3000/listen/...).
  Prefer HTTPS for production ablaut servers when possible.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
